# Server-only secrets — configure in Google AI Studio / Cloud Run Secrets.
GEMINI_API_KEY=replace_me
GOOGLE_CLOUD_PROJECT=demo-kintsugi
FIREBASE_STORAGE_BUCKET=demo-kintsugi.appspot.com
INTERNAL_AGENT_SECRET=replace_with_32_or_more_random_characters
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
PORT=8080
NODE_ENV=development

# Public Firebase web configuration (these identify the app; authorization is enforced by rules and App Check).
VITE_FIREBASE_API_KEY=demo-api-key
VITE_FIREBASE_AUTH_DOMAIN=demo-kintsugi.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=demo-kintsugi
VITE_FIREBASE_STORAGE_BUCKET=demo-kintsugi.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:demo
VITE_API_BASE_URL=http://localhost:8080
VITE_USE_FIREBASE_EMULATORS=true
VITE_GOOGLE_MAPS_MAP_ID=replace_me

# Firebase Admin SDK emulator routing (local development only)
FIRESTORE_EMULATOR_HOST=127.0.0.1:8081
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199
