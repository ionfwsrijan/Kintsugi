rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function roleIs(role) { return signedIn() && request.auth.token.role == role; }
    function assignedToWard(wardId) { return roleIs('admin') || (roleIs('authority') && wardId in request.auth.token.wardIds); }

    match /issues/{issueId} {
      allow read: if signedIn();
      allow create, update, delete: if false; // all mutations pass through the validated API
      match /events/{eventId} { allow read: if signedIn(); allow write: if false; }
      match /verifications/{uid} { allow read: if signedIn() && (request.auth.uid == uid || roleIs('admin')); allow write: if false; }
    }
    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || roleIs('admin'));
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if signedIn() && request.auth.uid == uid && request.resource.data.role == resource.data.role;
      allow delete: if false;
    }
    match /{document=**} { allow read, write: if false; }
  }
}
