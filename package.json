{
  "name": "kintsugi-community-hero",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@11.5.1",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:win": "set \"PATH=C:\\Program Files\\nodejs;%PATH%\" && .\\node_modules\\.bin\\vite.CMD --host 0.0.0.0",
    "dev:server": "tsx watch server/index.ts",
    "dev:server:win": "set \"PATH=C:\\Program Files\\nodejs;%PATH%\" && .\\node_modules\\.bin\\tsx.CMD watch server/index.ts",
    "build": "tsc -b && vite build",
    "build:win": "set \"PATH=C:\\Program Files\\nodejs;%PATH%\" && .\\node_modules\\.bin\\tsc.CMD -b && .\\node_modules\\.bin\\vite.CMD build",
    "build:server": "tsc -p server/tsconfig.json",
    "build:server:win": "set \"PATH=C:\\Program Files\\nodejs;%PATH%\" && .\\node_modules\\.bin\\tsc.CMD -p server/tsconfig.json",
    "start": "node server-dist/index.js",
    "test": "vitest run",
    "test:win": "set \"PATH=C:\\Program Files\\nodejs;%PATH%\" && .\\node_modules\\.bin\\vitest.CMD run",
    "preview": "vite preview --host 0.0.0.0",
    "preview:win": "set \"PATH=C:\\Program Files\\nodejs;%PATH%\" && .\\node_modules\\.bin\\vite.CMD preview --host 0.0.0.0",
    "emulators": "firebase emulators:start --import=.firebase-data --export-on-exit=.firebase-data"
  },
  "dependencies": {
    "@google/genai": "^1.28.0",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "firebase": "^12.6.0",
    "firebase-admin": "^13.6.0",
    "helmet": "^8.1.0",
    "lucide-react": "^0.552.0",
    "multer": "^2.0.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.3.0",
    "typescript": "~5.9.3",
    "vite": "^7.1.12",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/multer": "^2.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "firebase-tools": "^14.25.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.4.0",
    "vitest": "^4.0.8"
